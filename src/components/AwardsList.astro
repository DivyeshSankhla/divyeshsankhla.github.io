---
import type { AwardEntry, VolunteerEntry } from '../lib/types';

interface Props {
  awards: AwardEntry[];
  volunteer: VolunteerEntry[];
}

const { awards, volunteer } = Astro.props;
---

<h2 class="section-title" id="honors-and-awards">Honors and Awards</h2>
<div class="table-wrap">
  <table class="portfolio-table simple-table">
    <tbody>
      {
        awards.map((award) => (
          <tr>
            <td>
              🏆 {award.title}
              {award.detail && (
                <>
                  <br />
                  <span class="muted">{award.detail}</span>
                </>
              )}
              {award.link && (
                <>
                  <br />
                  <a href={award.link} target="_blank" rel="noopener noreferrer">
                    Certificate
                  </a>
                </>
              )}
            </td>
          </tr>
        ))
      }
    </tbody>
  </table>
</div>

<h2 class="section-title" id="volunteer-experience">Volunteer Experience</h2>
<div class="table-wrap">
  <table class="portfolio-table simple-table">
    <tbody>
      {
        volunteer.map((entry) => (
          <tr>
            <td>{entry.text}</td>
          </tr>
        ))
      }
    </tbody>
  </table>
</div>
