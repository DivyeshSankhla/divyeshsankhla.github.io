---
import type { EducationEntry } from '../lib/types';

interface Props {
  entries: EducationEntry[];
}

const { entries } = Astro.props;
---

<h2 class="section-title" id="education">Education</h2>
<div class="table-wrap">
  <table class="portfolio-table portfolio-table--experience">
    <tbody>
      {
        entries.map((entry) => (
          <tr>
            <td class="col-meta">
              <div class="org-card org-card--education">
                {entry.logo && (
                  <img
                    class="org-logo"
                    src={entry.logo}
                    alt=""
                    width="88"
                    height="72"
                  />
                )}
                <strong class="org-name">{entry.school}</strong>
                <span class="org-location org-location--education">{entry.location}</span>
              </div>
            </td>
            <td class="col-content education-details">
              <span class="org-dates education-dates">
                {entry.start} – {entry.end}
              </span>
              <span class="education-degree">{entry.degree}</span>
              {entry.department && (
                <span class="education-department">{entry.department}</span>
              )}
              {entry.details && <span class="education-gpa">{entry.details}</span>}
              {entry.coursework && entry.coursework.length > 0 && (
                <span class="education-coursework">
                  Relevant coursework: {entry.coursework.join(', ')}
                </span>
              )}
              {entry.honor && <span class="education-honor">{entry.honor}</span>}
              {entry.links && entry.links.length > 0 && (
                <p class="education-links">
                  {entry.links.map((link, index) => (
                    <>
                      {index > 0 && ' '}
                      <a href={link.url} target="_blank" rel="noopener noreferrer">
                        {link.label}
                      </a>
                    </>
                  ))}
                </p>
              )}
            </td>
          </tr>
        ))
      }
    </tbody>
  </table>
</div>
