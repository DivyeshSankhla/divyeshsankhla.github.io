---
import type { EducationEntry } from '../lib/types';

interface Props {
  entries: EducationEntry[];
}

const { entries } = Astro.props;
---

<h2 class="section-title" id="education">Education</h2>
<div class="table-wrap">
  <table class="portfolio-table portfolio-table--experience">
    <tbody>
      {
        entries.map((entry) => (
          <tr>
            <td class="col-meta">
              <div class="org-card org-card--education">
                {entry.logo && (
                  <img
                    class="org-logo"
                    src={entry.logo}
                    alt=""
                    width="88"
                    height="72"
                  />
                )}
                <strong class="org-name">{entry.school}</strong>
                <span class="org-location">{entry.location}</span>
                <div class="org-role-block">
                  <span class="org-dates">
                    {entry.start} – {entry.end}
                  </span>
                  <span class="org-role">{entry.degree}</span>
                  {entry.department && (
                    <span class="org-detail">{entry.department}</span>
                  )}
                </div>
              </div>
            </td>
            <td class="col-content">
              {entry.details && <p class="role-summary">{entry.details}</p>}
              {entry.links && entry.links.length > 0 && (
                <p class="project-links">
                  {entry.links.map((link) => (
                    <a href={link.url} target="_blank" rel="noopener noreferrer">
                      {link.label}
                    </a>
                  ))}
                </p>
              )}
            </td>
          </tr>
        ))
      }
    </tbody>
  </table>
</div>
