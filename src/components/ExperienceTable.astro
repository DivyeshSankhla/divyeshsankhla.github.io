---
import type { ExperienceEntry } from '../lib/types';

interface Props {
  title?: string;
  entries: ExperienceEntry[];
}

const { title = 'Experience', entries } = Astro.props;
const sectionId = title === 'Experience' ? 'experience' : title.toLowerCase().replace(/[^a-z0-9]+/g, '-');
---

<h2 class="section-title" id={sectionId}>{title}</h2>
<div class="table-wrap">
  <table class="portfolio-table portfolio-table--experience">
    <tbody>
      {
        entries.map((entry) => (
          <tr>
            <td class="col-meta">
              <div class="org-card">
                {entry.logo && (
                  <img
                    class="org-logo"
                    src={entry.logo}
                    alt=""
                    width="72"
                    height="72"
                  />
                )}
                <strong class="org-name">{entry.company}</strong>
                <span class="org-location">{entry.location}</span>
                <div class="org-role-block">
                  <span class="org-dates">
                    {entry.start} – {entry.end}
                  </span>
                  <span class="org-role">{entry.role}</span>
                </div>
              </div>
            </td>
            <td class="col-content">
              {
                entry.projectSummaries.map((project) => (
                  <div class="role-project-summary">
                    <strong>{project.title}</strong>
                    <p class="role-summary">{project.summary}</p>
                  </div>
                ))
              }
            </td>
          </tr>
        ))
      }
    </tbody>
  </table>
</div>
