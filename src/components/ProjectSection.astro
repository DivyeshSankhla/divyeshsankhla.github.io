---
import type { ProjectCategory } from '../lib/types';

interface Props {
  categories: ProjectCategory[];
}

const { categories } = Astro.props;

const tierOrder = { featured: 0, production: 1, academic: 2, other: 3 };

function sortProjects(categories: ProjectCategory[]) {
  return categories.map((category) => ({
    ...category,
    projects: [...category.projects].sort(
      (a, b) => tierOrder[a.tier] - tierOrder[b.tier],
    ),
  }));
}

const sortedCategories = sortProjects(categories);
---

<h2 class="section-title" id="projects">Projects</h2>
{
  sortedCategories.map((category) => (
    <>
      <h3 class="subsection-title">{category.name}</h3>
      <div class="table-wrap">
        <table class="portfolio-table">
          <tbody>
            {category.projects.map((project) => (
              <tr>
                <td class="col-meta">
                  <div class="project-meta">
                    <strong class="project-meta__title">{project.title}</strong>
                    <span class="project-meta__org">
                      {project.org === 'Personal'
                        ? 'Personal'
                        : `Organization: ${project.org}`}
                    </span>
                  </div>
                  {project.links && project.links.length > 0 && (
                    <p class="project-links">
                      {project.links.map((link) => (
                        <a href={link.url} target="_blank" rel="noopener noreferrer">
                          {link.label}
                        </a>
                      ))}
                    </p>
                  )}
                </td>
                <td class="col-content">
                  {project.context && (
                    <p class="project-context">{project.context}</p>
                  )}
                  {project.summary && (
                    <p class="project-summary">{project.summary}</p>
                  )}
                  <span class="project-tech">{project.tech.join(', ')}</span>
                  {project.focuses && project.focuses.length > 0 ? (
                    <div class="project-focuses">
                      {project.focuses.map((focus) => (
                        <div class="project-focus">
                          <span class="project-focus-title">{focus.title}</span>
                          {focus.highlights.length > 0 && (
                            <ul>
                              {focus.highlights.map((item) => (
                                <li>{item}</li>
                              ))}
                            </ul>
                          )}
                        </div>
                      ))}
                    </div>
                  ) : (
                    project.highlights &&
                    project.highlights.length > 0 && (
                      <ul>
                        {project.highlights.map((item) => (
                          <li>{item}</li>
                        ))}
                      </ul>
                    )
                  )}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </>
  ))
}
